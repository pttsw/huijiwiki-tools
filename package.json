{
  "name": "huijiwiki-tools",
  "version": "1.0.0",
  "description": "HuijiWiki batch operation tools",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "upload": "node tools/batch-upload-images.js",
    "upload:dry-run": "node tools/batch-upload-images.js --dry-run",
    "upload:pages": "node tools/batch-upload-pages.js",
    "upload:pages:dry-run": "node tools/batch-upload-pages.js --dry-run",
    "get:page": "node tools/batch-upload-pages.js --config ./config/upload.config.page.json",
    "get:page:dry-run": "node tools/batch-upload-pages.js --config ./config/upload.config.page.json --dry-run",
    "get:json": "node tools/batch-upload-pages.js --config ./config/upload.config.output.json",
    "get:json:dry-run": "node tools/batch-upload-pages.js --config ./config/upload.config.output.json --dry-run",
    "test": "node --test"
  },
  "dependencies": {
    "huijiwiki-api": "^0.8.4"
  }
}
